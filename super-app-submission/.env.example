# Super App — Environment Variables
# Copy this file to .env and fill in your API keys.
# The app works without any keys (fallback data is used automatically).

# OMDb API — free key at http://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=your_omdb_api_key_here

# News API — free key at https://newsapi.org/register
VITE_NEWS_API_KEY=your_news_api_key_here

# OpenWeatherMap — free key at https://openweathermap.org/api
VITE_WEATHER_API_KEY=your_openweathermap_api_key_here
